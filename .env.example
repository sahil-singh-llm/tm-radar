# Cloudflare Worker URL — when set, the "Start Free Analysis" mode is enabled
# and visitors don't need their own Anthropic key. Leave empty to require BYOK.
VITE_WORKER_URL=

# Optional: Cloudflare Turnstile site key for bot protection on the worker.
# Pair with the TURNSTILE_SECRET_KEY worker secret. Reserved for future use.
VITE_TURNSTILE_SITE_KEY=
